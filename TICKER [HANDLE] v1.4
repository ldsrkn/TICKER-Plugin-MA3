-- Format: table of 5 columns, each column = {row1..row5}, row1=top
-- All glyphs designed on 5x5 grid, readable at any scale multiple of 5

local function G(rows)
    local cols = {{},{},{},{},{}}
    for r = 1, 5 do
        local row = rows[r]
        for c = 1, 5 do cols[c][r] = tonumber(row:sub(c,c)) or 0 end
    end
    return cols
end

